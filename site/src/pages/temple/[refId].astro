---
import Base from "../../layouts/Base.astro";
import Name from "../../components/Name.astro";
import {
  temples,
  regionByCode,
  alwarsForTemple,
  alwarByCode,
  templeHistory,
  templeExtras,
  en,
  url,
} from "../../data";

export function getStaticPaths() {
  return temples.map((t) => ({ params: { refId: String(t.refId) }, props: { temple: t } }));
}
const { temple } = Astro.props;
const region = regionByCode.get(temple.regionCode);
const singingAlwars = alwarsForTemple(temple.refId)
  .map((c) => alwarByCode.get(c))
  .filter(Boolean);
const mapUrl = `https://www.openstreetmap.org/?mlat=${temple.lat}&mlon=${temple.lng}#map=15/${temple.lat}/${temple.lng}`;
const history = templeHistory[String(temple.refId)];
const historyParas = history ? history.history.split(/\n{2,}|\n/).map((p) => p.trim()).filter(Boolean) : [];
const extras = templeExtras[String(temple.refId)];
const festivalParas = extras?.festivals ? extras.festivals.split(/\n{2,}|\n/).map((p) => p.trim()).filter(Boolean) : [];
const timingParas = extras?.timings ? extras.timings.split(/\n{2,}|\n/).map((p) => p.trim()).filter(Boolean) : [];
const menuLabel: Record<string, string> = {
  HISTORY: "Sthala Puranam (Temple History)",
  ALWAR: "Mangalasasanam (Hymns of Praise)",
  FESTIVAL: "Festivals",
  TIME: "Timings & Routes",
};
---

<Base title={en(temple.name)} description={`${en(temple.name)}, ${en(temple.place)} — one of the 108 Divya Desam temples of Vishnu.`}>
  <div class="wrap">
    <p class="crumbs">
      <a href={url("/")}>Home</a>
      {region && <> › <a href={url(`/region/${region.code}`)}>{en(region.name)}</a></>}
      › {en(temple.place)}
    </p>

    <div class="twocol">
      <div>
        <img
          src={url(temple.images.zoom.local)}
          alt={en(temple.name)}
          style="width:100%; border-radius:12px; border:1px solid var(--line);"
        />
        <div class="panel" style="margin-top:1rem;">
          <div class="muted" style="font-size:.8rem; text-transform:uppercase; letter-spacing:.05em;">Location</div>
          <div class="ta">{temple.place.ta}</div>
          <p style="margin:.3rem 0;"><a href={mapUrl} target="_blank" rel="noopener">View on map ↗</a></p>
          <div class="muted" style="font-size:.85rem;">{temple.lat.toFixed(4)}, {temple.lng.toFixed(4)}</div>
        </div>
      </div>

      <div>
        <h1 style="margin-bottom:.2rem;">{en(temple.name)}</h1>
        <p class="ta muted" style="font-size:1.15rem; margin-top:0;">{temple.name.ta}</p>
        {!temple.name.en && (
          <p class="draft">English name awaiting translation — run the translation pipeline to populate.</p>
        )}
        <p><span class="pill">{en(temple.place)}</span> {region && <span class="pill">{en(region.name)}</span>}</p>

        <section class="section">
          <h2>Mangalasasanam</h2>
          {singingAlwars.length ? (
            <>
              <p class="muted">Alwars who sang the glories of this temple:</p>
              <ul class="clean">
                {singingAlwars.map((a) => (
                  <li><a href={url(`/alwar/${a!.code}`)}><Name value={a!.name} /></a></li>
                ))}
              </ul>
            </>
          ) : (
            <p class="muted">This is a celestial abode (not sung by the Alwars in earthly hymns).</p>
          )}
        </section>

        {historyParas.length > 0 && (
          <section class="section">
            <h2>Sthala Puranam <span class="ta muted" style="font-size:1rem;">தல புராணம்</span></h2>
            <div class="panel">
              {historyParas.map((p) => <p>{p}</p>)}
              <p class="draft" style="margin-top:.6rem;">
                AI-generated draft — a faithful summary under review; please verify against
                authoritative temple sources before relying on details.
              </p>
            </div>
          </section>
        )}

        {festivalParas.length > 0 && (
          <section class="section">
            <h2>Festivals <span class="ta muted" style="font-size:1rem;">திருவிழாக்கள்</span></h2>
            <div class="panel">
              {festivalParas.map((p) => <p>{p}</p>)}
              <p class="draft" style="margin-top:.6rem;">AI-generated draft — traditional festivals; dates vary each year, so confirm with the temple.</p>
            </div>
          </section>
        )}

        {timingParas.length > 0 && (
          <section class="section">
            <h2>Getting There <span class="ta muted" style="font-size:1rem;">நேரம் மற்றும் வழிகள்</span></h2>
            <div class="panel">
              {timingParas.map((p) => <p>{p}</p>)}
              <p class="draft" style="margin-top:.6rem;">AI-generated orientation — not official. Always verify current darshan timings and travel details with the temple before visiting.</p>
            </div>
          </section>
        )}
      </div>
    </div>
  </div>
</Base>
