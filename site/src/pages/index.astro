---
import Base from "../layouts/Base.astro";
import { regions, alwars, temples, en, slug, url } from "../data";
import Tr from "../components/Tr.astro";
const totalTemples = temples.length;
---

<Base title="The 108 Sacred Abodes of Vishnu">
  <section class="hero">
    <div class="wrap">
      <p class="pill">Naalayira Divya Prabandham</p>
      <h1>The 108 Divya Desam</h1>
      <p style="max-width:48rem; font-size:1.1rem;">
        The Divya Desams are the {totalTemples} sacred abodes of Sriman Narayana (Vishnu),
        glorified in the hymns of the twelve <strong>Alwar</strong> saints. This bilingual guide
        brings their names, histories, and sacred verses to readers everywhere — in English
        alongside the original Tamil.
      </p>
    </div>
  </section>

  <div class="wrap">
    <section class="section" id="regions">
      <h2><span class="l-en">Explore by Region</span><span class="l-te te">ప్రాంతం వారీగా</span><span class="l-kn kn">ಪ್ರಾಂತದ ಪ್ರಕಾರ</span></h2>
      <p class="muted">The temples are grouped into the traditional regions (<span class="ta">நாடு</span>, <em>nadu</em>) of the sacred geography.</p>
      <div class="grid cards" style="margin-top:1rem;">
        {regions.map((r) => (
          <a class="card" href={url(`/region/${r.code}`)}>
            <div class="body">
              <div class="en"><Tr v={r.name} /></div>
              <div class="sub muted ta">{r.name.ta}</div>
              <div class="sub" style="margin-top:.4rem;"><span class="pill">{r.templeCount} <span class="l-en">temples</span><span class="l-te te">ఆలయాలు</span><span class="l-kn kn">ದೇವಾಲಯಗಳು</span></span></div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="section" id="alwars">
      <h2><span class="l-en">The Twelve Alwars</span><span class="l-te te">పన్నెండు ఆళ్వార్లు</span><span class="l-kn kn">ಹನ್ನೆರಡು ಆಳ್ವಾರರು</span></h2>
      <p class="muted">The Alwars (<span class="ta">ஆழ்வார்கள்</span>) were poet-saints immersed in devotion to Vishnu, whose 4,000 Tamil verses form the Divya Prabandham.</p>
      <div class="grid cards" style="margin-top:1rem;">
        {alwars.map((a) => (
          <a class="card" href={url(`/alwar/${a.code}`)}>
            {a.image && <img src={url(a.image.local)} alt={en(a.name)} loading="lazy" />}
            <div class="body">
              <div class="en"><Tr v={a.name} /></div>
              <div class="sub muted ta">{a.name.ta}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</Base>
