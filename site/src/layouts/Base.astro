---
interface Props {
  title: string;
  description?: string;
  taTitle?: string;
}
import { url } from "../data";
const { title, description, taTitle } = Astro.props;
const desc =
  description ??
  "The 108 Divya Desam — the sacred abodes of Vishnu revered by the twelve Alwar saints in the Naalayira Divya Prabandham. Temple guide, hymns, and meanings in English and Tamil.";
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Apply saved language before paint to avoid a flash.
      try { var L = localStorage.getItem("lang"); if (L === "te" || L === "kn") document.documentElement.classList.add("lang-" + L); } catch (e) {}
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · 108 Divya Desam</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="ta" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&family=Noto+Sans+Tamil:wght@400;600&family=Noto+Sans+Telugu:wght@400;600&family=Noto+Sans+Kannada:wght@400;600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #fbf7ef;
        --surface: #fffdf8;
        --ink: #2a2018;
        --muted: #7a6a57;
        --accent: #b5471f;
        --accent-soft: #e9d9c4;
        --line: #e7ddcb;
        --gold: #b08828;
        --maxw: 1100px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: Inter, system-ui, sans-serif;
        line-height: 1.6;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 1.25rem; }
      h1, h2, h3 { font-family: Fraunces, Georgia, serif; font-weight: 600; line-height: 1.15; }
      .ta { font-family: "Noto Sans Tamil", sans-serif; }
      .muted { color: var(--muted); }
      .translit { font-style: italic; color: var(--muted); }
      header.site {
        background: var(--surface);
        border-bottom: 1px solid var(--line);
        position: sticky; top: 0; z-index: 10;
      }
      header.site .wrap { display: flex; align-items: center; gap: 1rem; padding: 0.7rem 1.25rem; }
      header.site .brand { font-family: Fraunces, serif; font-weight: 600; font-size: 1.15rem; color: var(--ink); }
      header.site .brand b { color: var(--accent); }
      header.site nav { margin-left: auto; display: flex; gap: 1.1rem; font-size: 0.95rem; }
      footer.site { border-top: 1px solid var(--line); margin-top: 3rem; color: var(--muted); font-size: 0.9rem; }
      footer.site .wrap { padding: 1.5rem 1.25rem; }
      .grid { display: grid; gap: 1rem; }
      .cards { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 12px;
        overflow: hidden;
        transition: transform .12s ease, box-shadow .12s ease;
      }
      .card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(80,50,20,.10); text-decoration: none; }
      .card img { width: 100%; aspect-ratio: 16/10; object-fit: cover; display: block; background: var(--accent-soft); }
      .card .body { padding: .75rem .9rem; }
      .card .en { font-family: Fraunces, serif; font-weight: 600; }
      .card .sub { font-size: .85rem; }
      .pill { display:inline-block; font-size:.72rem; letter-spacing:.04em; text-transform:uppercase; color:var(--gold); border:1px solid var(--accent-soft); border-radius:999px; padding:.1rem .55rem; }
      .hero { background: linear-gradient(180deg, #fff8ec, var(--bg)); border-bottom: 1px solid var(--line); }
      .hero .wrap { padding: 2.5rem 1.25rem; }
      .hero h1 { font-size: clamp(2rem, 5vw, 3rem); margin: 0 0 .4rem; }
      .crumbs { font-size: .85rem; margin: 1rem 0; }
      .section { margin: 2rem 0; }
      .twocol { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
      @media (min-width: 820px) { .twocol { grid-template-columns: 320px 1fr; } }
      .panel { background: var(--surface); border: 1px solid var(--line); border-radius: 12px; padding: 1rem 1.2rem; }
      .verse { padding: .9rem 0; border-bottom: 1px dashed var(--line); }
      .verse .num { font-size:.75rem; color: var(--gold); }
      .verse .ta { white-space: pre-line; font-size: 1.05rem; }
      .verse .translit { white-space: pre-line; display:none; color: var(--muted); }
      .verse .meaning { display:block; margin-top:.4rem; color: var(--ink); border-left: 3px solid var(--accent-soft); padding-left:.7rem; }
      body.show-translit .verse .translit { display:block; }
      body.hide-meaning .verse .meaning { display:none; }
      .toolbar { position: sticky; top: 56px; background: var(--bg); padding:.6rem 0; display:flex; gap:.5rem; flex-wrap:wrap; z-index: 5; }
      .toggle { font: inherit; font-size:.85rem; cursor:pointer; border:1px solid var(--line); background:var(--surface); color:var(--ink); padding:.3rem .8rem; border-radius:999px; }
      .toggle[aria-pressed="true"] { background: var(--accent); color:#fff; border-color: var(--accent); }
      .draft { font-size:.7rem; color: var(--gold); }
      .te { font-family: "Noto Sans Telugu", sans-serif; }
      .kn { font-family: "Noto Sans Kannada", sans-serif; }
      /* Language switch: English by default; html.lang-te / .lang-kn flip the page. */
      .l-te, .l-kn { display: none; }
      .l-te-b, .l-kn-b { display: none; }
      html.lang-te .l-en { display: none; } html.lang-te .l-te { display: inline; }
      html.lang-te .l-en-b { display: none; } html.lang-te .l-te-b { display: block; }
      html.lang-kn .l-en { display: none; } html.lang-kn .l-kn { display: inline; }
      html.lang-kn .l-en-b { display: none; } html.lang-kn .l-kn-b { display: block; }
      .langbtn { font: inherit; font-size: .9rem; cursor: pointer; border: 1px solid var(--accent); background: var(--surface); color: var(--accent); padding: .25rem .5rem; border-radius: 999px; }
      ul.clean { list-style:none; padding:0; margin:0; }
      ul.clean li { padding:.35rem 0; border-bottom:1px solid var(--line); }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <a class="brand" href={url("/")}>108 <b>Divya Desam</b></a>
        <nav>
          <a href={url("/#regions")}><span class="l-en">Regions</span><span class="l-te te">ప్రాంతాలు</span><span class="l-kn kn">ಪ್ರಾಂತಗಳು</span></a>
          <a href={url("/#alwars")}><span class="l-en">Alwars</span><span class="l-te te">ఆళ్వార్లు</span><span class="l-kn kn">ಆಳ್ವಾರರು</span></a>
          <a href={url("/prabandham")}><span class="l-en">Hymns</span><span class="l-te te">పాశురాలు</span><span class="l-kn kn">ಪಾಶುರಗಳು</span></a>
          <a href={url("/about")}><span class="l-en">About</span><span class="l-te te">గురించి</span><span class="l-kn kn">ಬಗ್ಗೆ</span></a>
          <select id="langsel" class="langbtn" aria-label="Language">
            <option value="en">English</option>
            <option value="te">తెలుగు</option>
            <option value="kn">ಕನ್ನಡ</option>
          </select>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      <div class="wrap">
        <p>
          <strong>108 Divya Desam</strong> — a bilingual guide to the sacred abodes of Sriman
          Narayana, sung by the twelve Alwars in the Naalayira Divya Prabandham.
        </p>
        <p class="muted">
          Source content adapted from the <strong>“108 Divya Desam” Tamil Android app</strong> by
          CodeRays (<a href="https://play.google.com/store/apps/details?id=com.coderays.divyadesam" target="_blank" rel="noopener">Google&nbsp;Play</a>),
          with gratitude. Temple imagery © its respective publisher.
        </p>
        <p class="muted">
          English transliterations and meanings are machine-assisted drafts under review; the Tamil
          source text is preserved throughout as the authority.
        </p>
      </div>
    </footer>
    <script is:inline>
      const sel = document.getElementById("langsel");
      if (sel) {
        const h = document.documentElement;
        sel.value = h.classList.contains("lang-te") ? "te" : h.classList.contains("lang-kn") ? "kn" : "en";
        sel.addEventListener("change", () => {
          h.classList.remove("lang-te", "lang-kn");
          if (sel.value !== "en") h.classList.add("lang-" + sel.value);
          try { localStorage.setItem("lang", sel.value); } catch (e) {}
        });
      }
    </script>
  </body>
</html>
